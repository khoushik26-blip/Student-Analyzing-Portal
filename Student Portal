<script>
/* ── SCROLL REVEAL ─────────────────────────────── */
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      // animate bars inside
      e.target.querySelectorAll('.bar-anim').forEach(bar => {
        bar.style.width = bar.dataset.target + '%';
      });
      // animate metric values
      const ids = [{id:'acc-val',v:95},{id:'prec-val',v:93},{id:'rec-val',v:91},{id:'f1-val',v:92}];
      ids.forEach(({id,v}) => {
        const el = document.getElementById(id);
        if (el && el.textContent === '0%') animateCount(el, v);
      });
      // animate algo bars
      e.target.querySelectorAll('.algo-bar-fill').forEach(b => b.classList.add('animate'));
    }
  });
}, { threshold: 0.15 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

function animateCount(el, target) {
  let current = 0;
  const step = target / 60;
  const timer = setInterval(() => {
    current = Math.min(current + step, target);
    el.textContent = Math.round(current) + '%';
    if (current >= target) clearInterval(timer);
  }, 25);
}

/* ── PREDICTION DEMO ───────────────────────────── */
function predict() {
  const hours = parseFloat(document.getElementById('study_hours').value) || 0;
  const attend = parseFloat(document.getElementById('attendance').value) || 0;
  const gpa = parseFloat(document.getElementById('gpa').value) || 0;
  const part = document.getElementById('participation').value;
  const fam = document.getElementById('family').value;
  const comp = parseFloat(document.getElementById('completion').value) || 0;

  let score = 0;
  score += Math.min(hours / 40, 1) * 25;
  score += (attend / 100) * 30;
  score += (gpa / 10) * 25;
  score += (comp / 100) * 10;
  if (part === 'high') score += 5;
  else if (part === 'medium') score += 3;
  if (fam === 'strong') score += 5;
  else if (fam === 'moderate') score += 2.5;

  const rb = document.getElementById('result-box');
  const rt = document.getElementById('result-title');
  const rd = document.getElementById('result-desc');
  const bars = document.getElementById('result-bars');
  rb.style.display = 'block';
  rb.className = '';

  const algo = document.getElementById('algo').value;
  const algoMap = {rf:'Random Forest',ensemble:'Ensemble',dt:'Decision Tree',lr:'Logistic Regression'};
  const algoName = algoMap[algo];

  let confidence = Math.round(75 + (score / 100) * 20 + Math.random() * 5);
  confidence = Math.min(confidence, 98);

  if (score >= 70) {
    rb.classList.add('high');
    rt.innerHTML = `<span style="color:#10b981">✅ High Performance Predicted</span>`;
    rd.innerHTML = `<strong>${algoName}</strong> predicts this student is on track for strong academic results (${confidence}% confidence). Key drivers: good attendance, consistent study habits, and solid completion rate.`;
  } else if (score >= 45) {
    rb.classList.add('medium');
    rt.innerHTML = `<span style="color:#f59e0b">⚠️ Moderate Risk — Needs Monitoring</span>`;
    rd.innerHTML = `<strong>${algoName}</strong> identifies moderate risk (${confidence}% confidence). Recommend increasing study hours, improving attendance, and boosting classroom participation.`;
  } else {
    rb.classList.add('low');
    rt.innerHTML = `<span style="color:#ef4444">🚨 At-Risk — Immediate Intervention Needed</span>`;
    rd.innerHTML = `<strong>${algoName}</strong> flags this student as high risk (${confidence}% confidence). Urgent educator outreach recommended. Focus areas: attendance, assignment completion, and family support.`;
  }

  bars.innerHTML = `
    <div style="flex:1;min-width:140px">
      <div style="font-size:.72rem;color:var(--muted);margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.06em">Predictive Score</div>
      <div style="font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--bright)">${Math.round(score)}<span style="font-size:1rem;color:var(--muted)">/100</span></div>
    </div>
    <div style="flex:1;min-width:140px">
      <div style="font-size:.72rem;color:var(--muted);margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.06em">Model Confidence</div>
      <div style="font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--bright)">${confidence}<span style="font-size:1rem;color:var(--muted)">%</span></div>
    </div>
    <div style="flex:1;min-width:140px">
      <div style="font-size:.72rem;color:var(--muted);margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.06em">Algorithm</div>
      <div style="font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--bright);line-height:1.3">${algoName}</div>
    </div>
  `;
}
</script>
